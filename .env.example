# Copy this file to .env and fill in your real values.

# Get BOT_TOKEN from @BotFather in Telegram after /newbot.
BOT_TOKEN=123456789:AA...your-bot-token-here

# Get a free MongoDB Atlas connection string (takes ~10 minutes):
# 1. Go to https://www.mongodb.com/cloud/atlas/register â€” sign up free
# 2. Create a free "M0" cluster (no credit card needed)
# 3. Database Access â†’ add a user + password
# 4. Network Access â†’ "Allow access from anywhere" (0.0.0.0/0)
# 5. Connect â†’ "Drivers" â†’ copy the connection string, paste below,
#    replacing <password> with your real password
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/vtuber_market?retryWrites=true&w=majority

# Any secret string you choose â€” required to call the /api/admin/whitelist
# endpoints (adding/removing sponsor Telegram ids for free access).
ADMIN_KEY=change-me-to-a-long-random-secret

# Monthly subscription price, in Telegram Stars.
SUBSCRIPTION_PRICE=1500

# Port the API listens on (Render/Railway usually set this automatically)
PORT=3000
